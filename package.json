{
  "name": "claude-telegram-bridge",
  "version": "3.1.0",
  "description": "Two-way Telegram chat bridge for Claude Code. Send/receive text, photos, videos, voice messages, files, inline buttons. Includes Whisper audio transcription and video keyframe extraction.",
  "author": "OCS CommTech LLC <contact@ocscommtech.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lordoftruth74/claude-telegram-bridge"
  },
  "keywords": [
    "claude",
    "claude-code",
    "mcp",
    "telegram",
    "telegram-bot",
    "model-context-protocol",
    "vscode",
    "ai",
    "bridge"
  ],
  "main": "build/index.js",
  "bin": {
    "claude-telegram-bridge": "build/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node build/index.js",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "node-telegram-bot-api": "^0.66.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/node-telegram-bot-api": "^0.64.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
